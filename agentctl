#!/usr/bin/env python3
"""agentctl — Lifecycle management per agenti CLI in tmux.

Standalone: nessuna dipendenza da server HTTP o agent-bus.
Usa solo tmux + un file JSON locale per registrare le sessioni.
I tmux sono workspace per l'utente — Hermes orchestra via delegate_task.

Allo spawn: health check automatico (duplicati + carico anomalo).
Se rileva problemi: big warning + auto-pulizia dopo 2 minuti.

Usage:
  agentctl spawn <codex|claude|agy> [--name <session>] [--model <model>]
  agentctl send <agent> <message>
  agentctl capture <agent>
  agentctl list
  agentctl attach <agent>
  agentctl kill <agent>
  agentctl health [--json]
"""

import json
import os
import shutil
import signal
import subprocess
import sys
import threading
import time
from datetime import datetime, timezone
from pathlib import Path

# ── Config ──────────────────────────────────────────────────────────────
TMUX_TMPDIR = "/tmp"
os.environ.setdefault("TMUX_TMPDIR", TMUX_TMPDIR)
TMUX_BIN = shutil.which("tmux") or "/usr/local/bin/tmux"
STATE_FILE = Path.home() / ".hermes" / "agent-sessions.json"
LOG_DIR = Path.home() / ".hermes" / "agent-logs"

# Soglie health check
LOAD_WARN = 10    # load 1-min ≥ 10 → warning
LOAD_CRIT = 18    # load 1-min ≥ 18 → critico
CLEANUP_WAIT = 120  # secondi prima dell'auto-pulizia

CLI_MAP = {
    "codex":       ["codex"],
    "claude":      ["claude"],
    "claude-or":   ["claude-or"],
    "agy":         ["agy"],
}

# Flag file per cancellare l'auto-pulizia
CANCEL_FLAG = Path.home() / ".hermes" / "agentctl-cancel.flag"

_cleanup_cancelled = threading.Event()


# ── State management ────────────────────────────────────────────────────

def load_state() -> dict:
    if STATE_FILE.exists():
        try:
            with open(STATE_FILE) as f:
                return json.load(f)
        except (json.JSONDecodeError, OSError):
            pass
    return {}


def save_state(state: dict):
    STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)


def session_alive(session: str) -> bool:
    """Check if a tmux session exists."""
    r = subprocess.run(
        [TMUX_BIN, "has-session", "-t", session],
        capture_output=True, timeout=5,
    )
    return r.returncode == 0


# ── Health check ────────────────────────────────────────────────────────

def get_load_all() -> dict:
    """Ritorna {1m, 5m, 15m} load."""
    try:
        raw = subprocess.run(
            ["sysctl", "-n", "vm.loadavg"],
            capture_output=True, timeout=3, text=True,
        ).stdout.strip()
        parts = raw.strip("{}").split()
        return {"1m": float(parts[0]), "5m": float(parts[1]), "15m": float(parts[2])}
    except (ValueError, IndexError, OSError):
        return {"1m": 0.0, "5m": 0.0, "15m": 0.0}


def check_all_agents() -> dict:
    """Health check completo su tutti gli agenti.

    Ritorna dict strutturato con load, processi per agente, anomalie.
    """
    load = get_load_all()
    state = load_state()

    # Costruisci known_pids da stato tmux
    known_pids = set()
    for a_data in state.values():
        sess = a_data.get("session", "")
        if sess and session_alive(sess):
            try:
                r = subprocess.run(
                    [TMUX_BIN, "list-panes", "-t", sess, "-F", "#{pane_pid}"],
                    capture_output=True, timeout=5, text=True,
                )
                for pid_str in r.stdout.strip().splitlines():
                    if pid_str and pid_str.isdigit():
                        pane_pid = int(pid_str)
                        known_pids.add(pane_pid)
                        # Includi discendenti (es. script → node → codex)
                        known_pids.update(get_descendants(pane_pid))
            except (ValueError, OSError, subprocess.TimeoutExpired):
                pass

    # ── Quota-monitoring transient sessions ───────────────────────
    # tmux sessions named ai_cli_quotas_* are created by the quota
    # monitoring system (api.py) every ~10min and last ~35s. Their
    # agent processes would appear as orphans/duplicates in the
    # health check. Exclude their PID trees from orphan detection.
    quota_pids = set()
    try:
        r = subprocess.run(
            [TMUX_BIN, "list-sessions", "-F", "#{session_name}"],
            capture_output=True, timeout=5, text=True,
        )
        for sess_name in r.stdout.strip().splitlines():
            if sess_name.startswith("ai_cli_quotas_"):
                r2 = subprocess.run(
                    [TMUX_BIN, "list-panes", "-t", sess_name, "-F", "#{pane_pid}"],
                    capture_output=True, timeout=5, text=True,
                )
                for pid_str in r2.stdout.strip().splitlines():
                    if pid_str and pid_str.isdigit():
                        pane_pid = int(pid_str)
                        quota_pids.add(pane_pid)
                        quota_pids.update(get_descendants(pane_pid))
    except (OSError, subprocess.TimeoutExpired):
        pass

    agents = {}
    all_anomalies = []

    for agent_name in sorted(CLI_MAP.keys()):
        procs = find_processes(agent_name)
        # Exclude quota-monitoring transient processes
        procs = [p for p in procs if p["pid"] not in quota_pids]
        orphans = [p for p in procs if p["pid"] not in known_pids]
        known = [p for p in procs if p["pid"] in known_pids]

        agent_info = {
            "count": len(procs),
            "processes": [
                {
                    "pid": p["pid"],
                    "ppid": p["ppid"],
                    "state": p["state"],
                    "in_tmux": p["in_tmux"],
                    "orphan": p["pid"] not in known_pids,
                }
                for p in procs
            ],
            "orphan_count": len(orphans),
            "known_count": len(known),
            "anomalies": [],
        }

        if len(procs) > 1:
            msg = f"{len(procs)} processi in esecuzione ({len(orphans)} orfani, {len(known)} registrati)"
            agent_info["anomalies"].append(f"DUPLICATES: {msg}")
            all_anomalies.append(f"{agent_name}: DUPLICATES — {msg}")
        elif len(procs) == 0 and agent_name in state:
            # Registrato ma morto
            agent_info["anomalies"].append("DEAD: registrato in stato ma nessun processo vivo")
            all_anomalies.append(f"{agent_name}: DEAD — registrato ma nessun processo vivo")

        agents[agent_name] = agent_info

    # Load anomalies
    if load["1m"] >= LOAD_CRIT:
        all_anomalies.insert(0, f"LOAD_CRIT: {load['1m']:.1f}")
    elif load["1m"] >= LOAD_WARN:
        all_anomalies.insert(0, f"LOAD_WARN: {load['1m']:.1f}")

    return {
        "load": load,
        "load_warn_threshold": LOAD_WARN,
        "load_crit_threshold": LOAD_CRIT,
        "agents": agents,
        "anomaly_count": len(all_anomalies),
        "anomalies": all_anomalies,
        "timestamp": datetime.now(timezone.utc).isoformat(),
    }


def get_descendants(pid: int) -> set[int]:
    """Ritorna tutti i PID discendenti (figli, nipoti, ...) di <pid>.

    Scansiona ps axo ppid,pid e costruisce l'albero in memoria,
    poi BFS/DFS dal PID radice.
    """
    descendants = set()
    try:
        r = subprocess.run(
            ["ps", "axo", "ppid,pid"],
            capture_output=True, timeout=3, text=True,
        )
        parent_map: dict[int, list[int]] = {}
        for line in r.stdout.splitlines()[1:]:
            parts = line.strip().split()
            if len(parts) == 2 and parts[0].isdigit() and parts[1].isdigit():
                pp = int(parts[0])
                cp = int(parts[1])
                parent_map.setdefault(pp, []).append(cp)

        stack = [pid]
        while stack:
            p = stack.pop()
            for child in parent_map.get(p, []):
                if child not in descendants:
                    descendants.add(child)
                    stack.append(child)
    except (OSError, subprocess.TimeoutExpired, ValueError):
        pass
    return descendants


def find_processes(agent: str) -> list[dict]:
    """Trova processi il cui eseguibile è <agent>.

    Usa `comm` (nome eseguibile, non cmdline) per evitare falsi
    positivi da script/tmux che hanno 'agy' nel path del log.

    Attenzione macOS: `ps axo comm` mostra il FULL PATH per alcuni
    eseguibili (codex via node). Usiamo un match substring cosi'
    che '/usr/local/.../codex' matchi 'codex'.

    Ritorna lista di dict: {pid, ppid, state, cmdline, in_tmux}
    """
    procs = []
    try:
        r = subprocess.run(
            ["ps", "axo", "pid,ppid,state,comm"],
            capture_output=True, timeout=5, text=True,
        )
        for line in r.stdout.splitlines()[1:]:
            parts = line.strip().split(None, 3)
            if len(parts) < 4:
                continue
            pid_s, ppid_s, state, comm = parts
            # comm e' il nome base o full path su macOS — filtra via basename
            comm_basename = os.path.basename(comm) if "/" in comm else comm
            # Script wrapper non va contato
            if comm_basename in ("script", "tmux"):
                continue
            if comm_basename != agent:
                continue
            # Prendi anche la cmdline completa per contesto
            cmdline = ""
            try:
                r2 = subprocess.run(
                    ["ps", "-p", pid_s, "-o", "command="],
                    capture_output=True, timeout=3, text=True,
                )
                cmdline = r2.stdout.strip()[:100]
            except OSError:
                pass
            in_tmux = "script -q" in cmdline
            procs.append({
                "pid": int(pid_s),
                "ppid": int(ppid_s),
                "state": state,
                "cmdline": cmdline or agent,
                "in_tmux": in_tmux,
            })
    except (subprocess.TimeoutExpired, OSError, ValueError):
        pass
    return procs


def find_orphans(agent: str, known_pids: set) -> list[dict]:
    """Trova processi <agent> che non sono registrati in stato.

    known_pids = set di PID che sono già nel nostro state (tmux registrati).
    """
    all_procs = find_processes(agent)
    orphans = [p for p in all_procs if p["pid"] not in known_pids]
    return orphans


def check_health(agent: str) -> list[str]:
    """Post-spawn health check. Ritorna lista di warning (vuota se OK)."""
    issues = []

    # 1. Carico sistema
    load = get_load_all()["1m"]
    if load >= LOAD_CRIT:
        issues.append(f"🚨 CARICO CRITICO: {load:.1f} (soglia: {LOAD_CRIT})")
    elif load >= LOAD_WARN:
        issues.append(f"⚠️  CARICO ANOMALO: {load:.1f} (soglia: {LOAD_WARN})")

    # 2. Conteggio processi
    procs = find_processes(agent)
    total = len(procs)

    # Escludi il processo appena spawnato (dentro tmux)
    state = load_state()
    known_pids = set()
    for a_data in state.values():
        sess = a_data.get("session", "")
        if sess and session_alive(sess):
            # Cerca agy/claude/codex annidato sotto script -q dentro quel tmux
            for p in procs:
                # Se il processo è sotto tmux/script ed è lo stesso tipo, lo consideriamo noto
                if p["in_tmux"] and p["pid"] not in known_pids:
                    # Check se il tmux session contiene questo processo
                    # Metodo semplice: c'è una relazione script→agent
                    known_pids.add(p["pid"])
                    break

    orphans = [p for p in procs if p["pid"] not in known_pids]

    if len(procs) > 1:
        issues.append(
            f"🔄 DUPLICATI: {total} processi '{agent}' in esecuzione"
            f" ({len(orphans)} orfani, {len(known_pids)} registrati)"
        )

    return issues


def print_big_warning(issues: list[str], agent: str, wait_sec: int):
    """Stampa un grosso warning con stile."""
    sep = "─" * 56
    print()

    # Intestazione
    print(sep)
    print(f"  ⚠️ ⚠️ ⚠️  HEALTH CHECK WARNING  ⚠️ ⚠️ ⚠️")
    print(sep)
    for issue in issues:
        print(f"  {issue}")
    print(sep)
    print()
    print(f"  ⏳ Tra {wait_sec} secondi pulisco automaticamente i duplicati")
    print(f"     e gli orfani. Per cancellare l'auto-pulizia:")
    print(f"       touch {CANCEL_FLAG}")
    print(f"     Oppure Ctrl+C ora per annullare.")
    print(sep)
    print()


def auto_clean(agent: str, issues: list[str], wait_sec: int):
    """Background thread: sleep, poi pulisce duplicati/orfani."""
    global _cleanup_cancelled

    # Sleep con check cancellazione ogni 10 sec
    for _ in range(wait_sec // 10):
        if _cleanup_cancelled.is_set():
            return
        if CANCEL_FLAG.exists():
            CANCEL_FLAG.unlink(missing_ok=True)
            print(f"\n[agentctl] Auto-pulizia cancellata.", file=sys.stderr)
            return
        time.sleep(10)

    if _cleanup_cancelled.is_set():
        return

    # Ri-valuta la situazione
    state = load_state()
    known_pids = set()

    for a_name, a_data in list(state.items()):
        sess = a_data.get("session", "")
        if sess and session_alive(sess):
            # Cerca il PID effettivo dentro la sessione tmux
            try:
                r = subprocess.run(
                    [TMUX_BIN, "list-panes", "-t", sess, "-F", "#{pane_pid}"],
                    capture_output=True, timeout=5, text=True,
                )
                for pid_str in r.stdout.strip().splitlines():
                    if pid_str:
                        known_pids.add(int(pid_str))
            except (ValueError, OSError, subprocess.TimeoutExpired):
                pass

    orphans = find_orphans(agent, known_pids)

    if not orphans:
        return  # Già risolto

    killed = 0
    for op in orphans:
        pid = op["pid"]
        try:
            os.kill(pid, signal.SIGTERM)
            time.sleep(0.3)
            if not os.path.exists(f"/proc/{pid}") and False:  # Linux-only
                pass
            # Su macOS, check ps dopo kill
            r = subprocess.run(
                ["ps", "-p", str(pid), "-o", "pid="],
                capture_output=True, timeout=3,
            )
            if r.returncode != 0:
                killed += 1
                continue
            # SIGKILL se persiste
            os.kill(pid, signal.SIGKILL)
            time.sleep(0.2)
            killed += 1
        except (ProcessLookupError, OSError):
            killed += 1  # Già morto

    if killed > 0:
        print(f"\n[agentctl] Auto-pulizia: {killed} processo/i '{agent}' orfano/i ucciso/i.",
              file=sys.stderr)


def tmux_checked(args: list[str], **kwargs) -> subprocess.CompletedProcess:
    """Run tmux and raise a useful error when the command fails."""
    result = subprocess.run(
        [TMUX_BIN, *args],
        capture_output=True,
        text=True,
        **kwargs,
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout or "").strip()
        raise RuntimeError(detail or f"tmux exited with {result.returncode}")
    return result


# ── Comandi ─────────────────────────────────────────────────────────────

def cmd_spawn(args: list[str]):
    """agentctl spawn <codex|claude|agy> [--name <session>] [--model <model>]"""
    import argparse
    parser = argparse.ArgumentParser(description="Avvia un agente in tmux")
    parser.add_argument("agent", choices=list(CLI_MAP.keys()),
                        help=f"Agente: {', '.join(CLI_MAP.keys())}")
    parser.add_argument("--name", help="Nome sessione tmux (opzionale)")
    parser.add_argument("--model", help="Modello override (es. claude-sonnet-4)")
    parser.add_argument("--workdir", "-d", help="Directory di lavoro (es. /path/to/project)")
    p = parser.parse_args(args)

    agent = p.agent
    session_name = p.name
    model = p.model
    workdir = p.workdir

    # Build CLI command
    cmd = list(CLI_MAP[agent])
    if model:
        cmd += ["--model", model]

    # Generate session name
    pid = os.getpid()
    session = session_name or f"agent-{agent}-{pid}"

    # Log file
    log_subdir = LOG_DIR / agent
    log_subdir.mkdir(parents=True, exist_ok=True)
    logfile = log_subdir / f"{datetime.now().strftime('%Y%m%d-%H%M%S')}.log"

    # Create tmux session with script logging
    tmux_cmd = [
        TMUX_BIN, "new-session", "-d", "-s", session,
    ]
    if workdir:
        tmux_cmd += ["-c", workdir]
    tmux_cmd += [
        "script", "-q", str(logfile),
    ] + cmd

    try:
        r = subprocess.run(tmux_cmd, capture_output=True, timeout=10)
        if r.returncode != 0:
            print(f"Errore: tmux new-session fallito: {r.stderr.decode()[:200]}",
                  file=sys.stderr)
            sys.exit(1)
    except Exception as e:
        print(f"Errore: {e}", file=sys.stderr)
        sys.exit(1)

    # Give it a moment
    time.sleep(1)

    # Command string for display + state
    cmd_str = " ".join(cmd)

    # Register in state
    state = load_state()
    state[agent] = {
        "session": session,
        "type": agent,
        "pid": pid,
        "spawned_at": time.time(),
        "model": model or "",
        "log": str(logfile),
        "command": cmd_str,
        "workdir": workdir or "",
    }
    save_state(state)

    # ── Health check post-spawn ─────────────────────────────────────
    issues = check_health(agent)
    if issues:
        print_big_warning(issues, agent, CLEANUP_WAIT)
        # Lancia auto-pulizia in background
        t = threading.Thread(
            target=auto_clean,
            args=(agent, issues, CLEANUP_WAIT),
            daemon=True,
        )
        t.start()
    # ─────────────────────────────────────────────────────────────────

    # Output
    print(f"✅ {agent} avviato in tmux")
    print(f"  Sessione: {session}")
    print(f"  Comando:  {cmd_str}")
    if workdir:
        print(f"  Directory: {workdir}")
    print(f"  Log:      {logfile}")
    print()
    print(f"  tmux attach -t {session}    (per attaccarti)")
    print(f"  Ctrl+B D                    (per staccarti)")
    print(f"  agentctl kill {agent}        (per fermarlo)")


def cmd_list(_args: list[str]):
    """agentctl list"""
    state = load_state()

    if not state:
        print("Nessun agente attivo.")
        return

    print(f"{'AGENTE':<12} {'SESSIONE':<24} {'DIR':<24} {'TMUX':<7} {'LOG':<6}")
    print("-" * 76)

    for agent, data in sorted(state.items()):
        session = data.get("session", "-")
        alive = session_alive(session) if session else False
        log_count = 0
        log_dir = LOG_DIR / agent
        if log_dir.is_dir():
            log_count = len(list(log_dir.glob("*.log")))
        workdir = data.get("workdir", "") or ""

        icon = "🟢" if alive else "🔴"
        print(f"{agent:<12} {str(session):<24} {str(workdir):<24} {icon:<7} {log_count:<6}")

    # Summary
    alive_count = sum(1 for d in state.values()
                      if d.get("session") and session_alive(d["session"]))
    total = len(state)
    print()
    print(f"{alive_count}/{total} agenti attivi")


def cmd_attach(args: list[str]):
    """agentctl attach <agent>"""
    if not args:
        print("Uso: agentctl attach <agent>", file=sys.stderr)
        sys.exit(1)

    agent = args[0]
    state = load_state()

    if agent not in state:
        print(f"Agente '{agent}' non trovato.", file=sys.stderr)
        sys.exit(1)

    session = state[agent].get("session", "?")
    print(f"Per attaccarti a '{agent}':")
    print(f"  tmux attach -t {session}")
    print(f"Per staccarti: Ctrl+B D (l'agente continua)")


def cmd_kill(args: list[str]):
    """agentctl kill <agent>"""
    if not args:
        print("Uso: agentctl kill <agent>", file=sys.stderr)
        sys.exit(1)

    agent = args[0]
    state = load_state()

    if agent not in state:
        print(f"Agente '{agent}' non trovato.", file=sys.stderr)
        sys.exit(1)

    session = state[agent].get("session")

    if session and session_alive(session):
        subprocess.run(
            [TMUX_BIN, "kill-session", "-t", session],
            capture_output=True, timeout=5,
        )
        print(f"✅ Sessione tmux '{session}' terminata.")
    else:
        print(f"⚠️  Sessione tmux '{session}' già terminata.")

    # Remove from state
    del state[agent]
    save_state(state)
    print(f"✅ Agente '{agent}' rimosso dal registro.")


def cmd_health(args: list[str]):
    """agentctl health [--json]

    Health check completo su tutti gli agenti (agy, claude, codex, claude-or).
    Default: output umano. Con --json: output JSON strutturato.
    """
    use_json = "--json" in args

    data = check_all_agents()

    if use_json:
        print(json.dumps(data, indent=2, default=str))
        return

    # Umano
    load = data["load"]
    sep = "─" * 52

    print(sep)
    print(f"  CARICO SISTEMA: {load['1m']:.1f} / {load['5m']:.1f} / {load['15m']:.1f}")
    if data["anomaly_count"] > 0:
        print(f"  ANOMALIE: {data['anomaly_count']}")
    else:
        print(f"  ✅ Tutto ok")
    print(sep)

    for agent_name, info in sorted(data["agents"].items()):
        if info["count"] == 0:
            print(f"  {agent_name:<12} — nessun processo")
            continue

        icon = "🟢" if info["orphan_count"] == 0 else "🟡"
        print(f"  {icon} {agent_name:<12} {info['count']} processi"
              f" ({info['known_count']} registrati, {info['orphan_count']} orfani)")
        for proc in info["processes"]:
            tag = " 🟢 tmux" if proc["in_tmux"] else " 🔴 orfano"
            print(f"     └ PID {proc['pid']:>6} {tag}  PPID={proc['ppid']} [{proc['state']}]")

    if data["anomalies"]:
        print()
        print("  ⚠️  ANOMALIE:")
        for a in data["anomalies"]:
            print(f"     • {a}")

    print(sep)


def cmd_send(args: list[str]):
    """agentctl send <agent> <message>

    Invia un messaggio a un agente in tmux.
    (Nessun Escape preventivo: interromperebbe un turno in corso — LB-49.)
    """
    if len(args) < 2:
        print("Uso: agentctl send <agent> <message>", file=sys.stderr)
        sys.exit(1)

    agent = args[0]
    message = " ".join(args[1:])
    state = load_state()

    if agent not in state:
        print(f"Agente '{agent}' non trovato.", file=sys.stderr)
        print("  Usa 'agentctl list' per vedere gli agenti attivi.", file=sys.stderr)
        sys.exit(1)

    session = state[agent].get("session")
    if not session:
        print(f"Agente '{agent}' non ha una sessione tmux.", file=sys.stderr)
        sys.exit(1)

    if not session_alive(session):
        print(f"Sessione tmux '{session}' non è più attiva.", file=sys.stderr)
        sys.exit(1)

    try:
        # LB-49 defect 3: NIENTE Escape preventivo — in Claude Code (e codex)
        # Esc interrompe il turno in corso, distruggendo la risposta alla
        # fonte. Costo accettato: un modal TUI aperto può assorbire il paste
        # (fallimento minore, visibile all'operatore).
        buffer_name = f"agentctl-{os.getpid()}-{int(time.time() * 1000)}"

        # Paste via a tmux buffer instead of send-keys -l. This is more reliable
        # for long prompts and keeps submission as a separate keystroke.
        tmux_checked(["load-buffer", "-b", buffer_name, "-"], input=message, timeout=5)
        tmux_checked(["paste-buffer", "-d", "-b", buffer_name, "-t", session], timeout=5)
        time.sleep(0.15)
        tmux_checked(["send-keys", "-t", session, "C-m"], timeout=5)
        print(f"✅ Messaggio inviato a '{agent}'")
    except Exception as e:
        print(f"Errore: {e}", file=sys.stderr)
        sys.exit(1)


def transcript_capture(entry: dict):
    """Ultima risposta completa dal transcript di sessione di Claude Code.

    Claude Code gira nell'alternate screen di tmux (LB-49 defect 1): il
    viewport è tutto ciò che capture-pane può mai vedere (history_size resta
    0), quindi le risposte lunghe sono irrecuperabili da tmux. Il CLI però
    scrive il transcript strutturato completo in
    ~/.claude/projects/<slug>/<session>.jsonl — si legge quello.

    Ritorna None se il transcript non c'è (il chiamante fa fallback su tmux).
    """
    workdir = entry.get("workdir") or ""
    if not workdir:
        return None
    proj = Path.home() / ".claude" / "projects" / workdir.replace("/", "-")
    if not proj.is_dir():
        return None
    files = sorted(proj.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
    if not files:
        return None

    lines = []
    try:
        with open(files[0]) as f:
            for raw in f:
                try:
                    lines.append(json.loads(raw))
                except json.JSONDecodeError:
                    continue
    except OSError:
        return None

    # Ultimo turno utente REALE (i tool_result arrivano come type:"user" ma
    # non sono l'operatore che parla — vanno saltati).
    last_user = -1
    for i, obj in enumerate(lines):
        if obj.get("type") != "user":
            continue
        content = (obj.get("message") or {}).get("content")
        if isinstance(content, str):
            last_user = i
        elif isinstance(content, list):
            if any(isinstance(b, dict) and b.get("type") == "tool_result" for b in content):
                continue
            if any(isinstance(b, dict) and b.get("type") == "text" for b in content):
                last_user = i

    chunks = []
    for obj in lines[last_user + 1:]:
        if obj.get("type") != "assistant":
            continue
        for b in (obj.get("message") or {}).get("content") or []:
            if isinstance(b, dict) and b.get("type") == "text" and b.get("text"):
                chunks.append(b["text"])
    if not chunks:
        return None
    return "\n\n".join(chunks).strip()


def cmd_capture(args: list[str]):
    """agentctl capture <agent>

    Mostra l'output recente di un agente in tmux.
    Utile per vedere la risposta dopo un send.
    """
    if not args:
        print("Uso: agentctl capture <agent>", file=sys.stderr)
        sys.exit(1)

    agent = args[0]
    state = load_state()

    if agent not in state:
        print(f"Agente '{agent}' non trovato.", file=sys.stderr)
        sys.exit(1)

    session = state[agent].get("session")
    if not session:
        print(f"Agente '{agent}' non ha sessione tmux.", file=sys.stderr)
        sys.exit(1)

    # LB-49 defect 1: per claude il pane è alternate-screen → si legge il
    # transcript di sessione (completo). Fallback su tmux se manca.
    if state[agent].get("type") == "claude":
        text = transcript_capture(state[agent])
        if text is not None:
            print(text)
            return

    try:
        # LB-49 defect 2: -S - cattura TUTTA la history (non il solo viewport
        # visibile); -J riunisce le righe wrappate a larghezza pane.
        r = subprocess.run(
            [TMUX_BIN, "capture-pane", "-t", session, "-p", "-S", "-", "-J"],
            capture_output=True, timeout=5, text=True,
        )
        if r.returncode == 0:
            print(r.stdout.strip())
        else:
            print(f"Errore: tmux capture-pane fallito.", file=sys.stderr)
            sys.exit(1)
    except Exception as e:
        print(f"Errore: {e}", file=sys.stderr)
        sys.exit(1)


